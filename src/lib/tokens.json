{
  "meta": {
    "source": "Paper design file — BTS Bookmark",
    "fileUrl": "https://app.paper.design/file/01KSMA9VM8K53HN6WD3VMPPCC3/1-0",
    "frames": [
      { "name": "Reader Main Page",   "width": 375, "height": 1820, "layers": 42 },
      { "name": "Reader Detail Page", "width": 375, "height": 745,  "layers": 6  }
    ],
    "fonts": ["Space Mono"]
  },

  "color": {
    "bg":          "#F7F6F2",
    "surface":     "#FFFFFF",
    "placeholder": "#DDDDDD",
    "ink":         "#000000",
    "accent":      "#FB304C",
    "text": {
      "body":   "#444444",
      "muted":  "#888888",
      "onDark": "#FFFFFF"
    },
    "avatar": {
      "bg": "#FCE7F3",
      "fg": "#9D174D"
    },
    "divider": "#EEEEEE"
  },

  "typography": {
    "fontFamily": "\"Space Mono\", system-ui, monospace",
    "styles": {
      "display": {
        "fontSize":   "20px",
        "fontWeight": 700,
        "lineHeight": "18px",
        "color":      "#000000",
        "usage": "Hero headline — CURATED CONTENT CONCERT"
      },
      "heading": {
        "fontSize":   "18px",
        "fontWeight": 700,
        "lineHeight": "22px",
        "color":      "#000000",
        "usage": "Section headings"
      },
      "headingOnDark": {
        "fontSize":   "18px",
        "fontWeight": 700,
        "lineHeight": "22px",
        "color":      "#FFFFFF",
        "usage": "Bottom bar labels (SCAM ALERT, FAQ)"
      },
      "body": {
        "fontSize":   "12px",
        "fontWeight": 400,
        "lineHeight": "16px",
        "color":      "#000000",
        "usage": "Page-level subtitle / description text"
      },
      "bodyOnDark": {
        "fontSize":   "12px",
        "fontWeight": 400,
        "lineHeight": "16px",
        "color":      "#FFFFFF",
        "usage": "Announcement band body text"
      },
      "cardBody": {
        "fontSize":   "10px",
        "fontWeight": 400,
        "lineHeight": "14px",
        "color":      "#444444",
        "usage": "Card tweet text — main page compact cards"
      },
      "cardBodySm": {
        "fontSize":   "9px",
        "fontWeight": 400,
        "lineHeight": "13px",
        "color":      "#444444",
        "usage": "Card tweet text — detail page / smaller variant"
      },
      "cta": {
        "fontSize":   "10px",
        "fontWeight": 700,
        "lineHeight": "12px",
        "color":      "#FB304C",
        "usage": "See More → CTA link"
      },
      "username": {
        "fontSize":   "9px",
        "fontWeight": 700,
        "lineHeight": "12px",
        "color":      "#000000",
        "usage": "Display name — compact main-page cards (28px avatar)"
      },
      "usernameLg": {
        "fontSize":   "11px",
        "fontWeight": 700,
        "lineHeight": "14px",
        "color":      "#000000",
        "usage": "Display name — detail-page / Twitter cards (30px avatar)"
      },
      "handle": {
        "fontSize":   "8px",
        "fontWeight": 400,
        "lineHeight": "10px",
        "color":      "#888888",
        "usage": "@handle / timestamp in card user row"
      },
      "metaStat": {
        "fontSize":   "8px",
        "fontWeight": 400,
        "lineHeight": "10px",
        "color":      "#888888",
        "usage": "Like count and comment count — compact"
      },
      "metaStatMd": {
        "fontSize":   "9px",
        "fontWeight": 400,
        "lineHeight": "12px",
        "color":      "#888888",
        "usage": "Like count and comment count — detail page"
      },
      "metaHeart": {
        "fontSize":   "8px",
        "fontWeight": 400,
        "lineHeight": "10px",
        "color":      "#FB304C",
        "usage": "Heart ♥ icon in stats row — compact"
      },
      "metaHeartMd": {
        "fontSize":   "9px",
        "fontWeight": 400,
        "lineHeight": "12px",
        "color":      "#FB304C",
        "usage": "Heart ♥ icon in stats row — detail page"
      },
      "avatarInitialsLg": {
        "fontSize":   "9px",
        "fontWeight": 700,
        "lineHeight": "12px",
        "color":      "#9D174D",
        "usage": "Initials inside 30px avatar circle"
      },
      "avatarInitialsSm": {
        "fontSize":   "8px",
        "fontWeight": 700,
        "lineHeight": "10px",
        "color":      "#9D174D",
        "usage": "Initials inside 28px avatar circle"
      }
    }
  },

  "spacing": {
    "1":  "2px",
    "2":  "4px",
    "3":  "5px",
    "4":  "6px",
    "5":  "8px",
    "6":  "10px",
    "7":  "12px",
    "8":  "16px",
    "9":  "24px",
    "10": "32px",
    "11": "36px",
    "semantic": {
      "pageMargin":      "32px",
      "cardPaddingX":    "12px",
      "cardPaddingY":    "10px",
      "cardStackOffset": "16px",
      "cardStackGap":    "12px",
      "rowGap":           "8px"
    }
  },

  "borderRadius": {
    "card":   "6px",
    "avatar": "50%"
  },

  "border": {
    "card":    "1px solid #FB304C",
    "divider": "1px solid #EEEEEE",
    "ink":     "1px solid #000000"
  },

  "shadow": {
    "card": "3px 6px 9px rgba(0, 0, 0, 0.2)"
  },

  "cardStack": {
    "rotate1": "2.2deg",
    "rotate2": "1.1deg"
  },

  "avatar": {
    "sizeLg": "30px",
    "sizeSm": "28px"
  },

  "layout": {
    "screenWidth": "375px"
  }
}
